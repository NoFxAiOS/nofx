+func hasAnyExpectedProtectionOrder(openOrders []OpenOrder, positionSide string, plan *ProtectionPlan, breakEvenArmed bool, nativeTrailingArmed bool) bool {
+	if breakEvenArmed || nativeTrailingArmed {
+		return true
+	}
+	if plan == nil {
+		return false
+	}
+
+	expectedStops := make(map[string]int)
+	expectedTPs := make(map[string]int)
+	for _, target := range plan.StopLossOrders {
+		expectedStops[fmt.Sprintf("%.8f", target.Price)]++
+	}
+	if len(plan.StopLossOrders) == 0 && plan.NeedsStopLoss && plan.StopLossPrice > 0 {
+		expectedStops[fmt.Sprintf("%.8f", plan.StopLossPrice)]++
+	}
+	if plan.FallbackMaxLossPrice > 0 {
+		expectedStops[fmt.Sprintf("%.8f", plan.FallbackMaxLossPrice)]++
+	}
+	for _, target := range plan.TakeProfitOrders {
+		expectedTPs[fmt.Sprintf("%.8f", target.Price)]++
+	}
+	if len(plan.TakeProfitOrders) == 0 && plan.NeedsTakeProfit && plan.TakeProfitPrice > 0 {
+		expectedTPs[fmt.Sprintf("%.8f", plan.TakeProfitPrice)]++
+	}
+
+	for _, order := range openOrders {
+		if positionSide != "" && order.PositionSide != "" && !strings.EqualFold(order.PositionSide, positionSide) {
+			continue
+		}
+		if strings.Contains(strings.ToUpper(order.Type), "TRAILING") {
+			continue
+		}
+		key := fmt.Sprintf("%.8f", order.StopPrice)
+		if looksLikeTakeProfit(order) {
+			if expectedTPs[key] > 0 {
+				return true
+			}
+			continue
+		}
+		if looksLikeStopLoss(order) {
+			if expectedStops[key] > 0 {
+				return true
+			}
+		}
+	}
+	return false
+}
